# Environment Configuration for EstateEase Remix - Example

# Database
DATABASE_URL=file:./data/estateease.db
DATABASE_PATH=./data/estateease.db

# Session Secret (generate a secure random string for production)
SESSION_SECRET=your-secret-key-here-replace-in-production

# Application
NODE_ENV=development
PORT=3000

# API Keys (if needed)
# OPENAI_API_KEY=your-openai-api-key
# ANTHROPIC_API_KEY=your-anthropic-api-key

# Feature Flags
ENABLE_AI_ADVISOR=false
ENABLE_DOCUMENT_PARSING=true
ENABLE_ADVANCED_ANALYTICS=false

# Storage
UPLOAD_DIR=./data/documents/uploads
MAX_FILE_SIZE=10485760  # 10MB in bytes

# Security
BCRYPT_ROUNDS=10
JWT_EXPIRES_IN=30d

# External Services (if needed)
# EMAIL_SERVICE_API_KEY=
# SMS_SERVICE_API_KEY=
# PAYMENT_GATEWAY_API_KEY=